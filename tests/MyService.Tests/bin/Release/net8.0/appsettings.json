{
  "Service": {
    "Name": "MyService",
    "Version": "1.0.0"
  },
  "Logging": {
    "Level": "Information",
    "Format": "console",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cache": {
    "DefaultTtlSeconds": 300,
    "Provider": "memory"
  },
  "RateLimiting": {
    "Global": {
      "PermitsPerWindow": 100,
      "WindowSeconds": 60
    }
  },
  "Auth": {
    "Issuer": "https://localhost",
    "Audience": "myservice",
    "SecretKey": "CHANGE-THIS-IN-PRODUCTION-minimum-32-chars!"
  },
  "HealthChecks": {
    "CacheDurationSeconds": 10
  },
  "Audit": {
    "Enabled": true,
    "HashChaining": true,
    "Sink": "file",
    "FilePath": "logs/audit.jsonl"
  },
  "AllowedHosts": "*"
}
